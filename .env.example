# ─────────────────────────────────────────────────────────────────────────────
# .env  (Docker Compose 로컬 실행용)
# Kubernetes 배포 시에는 k8s/configmap.yaml + k8s/secret.yaml 을 사용합니다.
# ─────────────────────────────────────────────────────────────────────────────

# ── MySQL ────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
DB_NAME=quizdb
DB_USER=quizuser
DB_PASSWORD=quizpassword
DB_HOST=db                          # Docker: 서비스명 'db' / k8s: mysql-service
DB_PORT=3306

# ── Flask ────────────────────────────────────────────────────────────────────
FLASK_DEBUG=false

# ── DB 연결 모드 ──────────────────────────────────────────────────────────────
# Docker: MySQL 연결 실패 시 SQLite로 대체 허용
# k8s:    MySQL 필수 (USE_SQLITE_FALLBACK=false, k8s/configmap.yaml 기준)
USE_SQLITE_FALLBACK=true

# ── Gemini AI ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_CANDIDATES=gemini-2.5-flash
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models
GEMINI_TIMEOUT=60
AI_REQUEST_BUDGET_SEC=40

# ── 기동 시 정리 옵션 ─────────────────────────────────────────────────────────
PURGE_DEFAULT_ON_BOOT=true
PURGE_SHORT_ON_BOOT=true
INIT_DB_SEED=false

# ── 서비스 URL (프론트 → 백엔드) ──────────────────────────────────────────────
# Docker: 서비스명 'backend' 사용
# k8s:    http://backend-service:5000  (k8s/configmap.yaml 기준)
BACKEND_URL=http://backend:5000
FRONTEND_PROXY_TIMEOUT=120
FRONTEND_PROXY_CONNECT_TIMEOUT=5

# ── Docker Hub (이미지 빌드/푸시 시 사용) ─────────────────────────────────────
DOCKER_HUB_USERNAME=your_dockerhub_username
BACKEND_IMAGE_TAG=0.7.1
FRONTEND_IMAGE_TAG=0.2.5
