# Copy to .env and fill values
# cp .env.example .env

# MySQL
MYSQL_ROOT_PASSWORD=rootpassword
DB_NAME=quizdb
DB_USER=quizuser
DB_PASSWORD=quizpassword
DB_HOST=db
DB_PORT=3306
USE_SQLITE_FALLBACK=true

# Flask
FLASK_DEBUG=false

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash-latest
GEMINI_MODEL_CANDIDATES=gemini-1.5-flash-latest,gemini-1.5-flash
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models
GEMINI_TIMEOUT=4
AI_REQUEST_BUDGET_SEC=18

# Startup maintenance
PURGE_DEFAULT_ON_BOOT=true
PURGE_SHORT_ON_BOOT=true
INIT_DB_SEED=false

# Service URL
BACKEND_URL=http://backend:5000
FRONTEND_PROXY_TIMEOUT=60

# Docker Hub
DOCKER_HUB_USERNAME=your_dockerhub_username
IMAGE_TAG=latest
