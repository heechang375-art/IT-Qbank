<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>IT 문제은행 - 이력</title>
  <link rel="stylesheet" href="/static/css/style.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.5.0/css/all.min.css" />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="logo">
        <i class="fa-solid fa-server"></i>
        <span>IT 문제은행</span>
      </a>
      <div class="review-meta" style="display:flex; gap:8px;">
        <button id="backToResultBtn" class="btn btn-sm btn-secondary" style="display:none;">
          <i class="fa-solid fa-chart-bar"></i> 결과로 돌아가기
        </button>
        <a href="/" class="btn btn-sm btn-primary"><i class="fa-solid fa-house"></i> 홈</a>
      </div>
    </div>
  </header>

  <main class="container main-content">
    <section class="card">
      <h2 class="section-title"><i class="fa-solid fa-clock-rotate-left"></i> 내 풀이 이력</h2>
      <div class="form-group">
        <label for="historyUser">이름</label>
        <div style="display:flex; gap:10px; align-items:center;">
          <input id="historyUser" class="form-input" placeholder="이름 입력" maxlength="30" />
          <button id="loadHistoryBtn" class="btn btn-secondary">
            <i class="fa-solid fa-magnifying-glass"></i> 조회
          </button>
        </div>
      </div>
      <div id="historyInfo" class="subtitle"></div>
      <div id="historyList"></div>
    </section>
  </main>

  <script>
  const API_BASE = "/api";
  const CATEGORY_LABEL = { network: "네트워크", infra: "인프라", linux: "리눅스" };
  const input = document.getElementById("historyUser");
  const info  = document.getElementById("historyInfo");
  const list  = document.getElementById("historyList");
  const qs    = new URLSearchParams(window.location.search);
  const savedName = sessionStorage.getItem("userName") || "";
  input.value = (qs.get("user") || savedName).trim();

  // 결과 데이터가 있으면 "결과로 돌아가기" 버튼 표시
  const hasResult = !!sessionStorage.getItem("quizResult");
  if (hasResult) {
    const backBtn = document.getElementById("backToResultBtn");
    backBtn.style.display = "inline-flex";
    backBtn.addEventListener("click", () => window.location.href = "/result");
  }

  function renderRows(items) {
    if (!items || items.length === 0) {
      list.innerHTML = '<p class="empty-msg">저장된 풀이 이력이 없습니다.</p>';
      return;
    }
    list.innerHTML = items.map((a) => {
      const catLabel = CATEGORY_LABEL[a.category] || a.category;
      const scoreClass = a.score_percent >= 80 ? "badge-gold"
                       : a.score_percent >= 60 ? "badge-correct" : "badge-wrong";
      return `
      <div class="review-card card" style="margin-top:12px">
        <div class="rc-header">
          <span class="rc-num">#${a.attempt_id}</span>
          <span class="rc-cat">${catLabel}</span>
          <span class="badge ${scoreClass}">${a.score_percent}%</span>
        </div>
        <p class="rc-question">총 ${a.total}문제 &nbsp;|&nbsp; 정답 <strong style="color:var(--success)">${a.correct}</strong> &nbsp;|&nbsp; 오답 <strong style="color:var(--danger)">${a.wrong}</strong></p>
        <div class="subtitle" style="margin-top:4px;">응시 시각(KST): ${a.created_at_kst}</div>
        <div style="margin-top:10px">
          <button class="btn btn-secondary btn-sm" onclick="openAttempt('${encodeURIComponent(input.value.trim())}', ${a.attempt_id})">
            <i class="fa-solid fa-eye"></i> 이 시도 다시보기
          </button>
        </div>
      </div>`;
    }).join("");
  }

  async function openAttempt(userEncoded, attemptId) {
    try {
      const res  = await fetch(`${API_BASE}/history/${userEncoded}/${attemptId}`);
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || `HTTP ${res.status}`);
      sessionStorage.setItem("userName", data.user_name || input.value.trim());
      sessionStorage.setItem("quizResult", JSON.stringify({
        total: data.total, correct: data.correct,
        wrong: data.wrong, score_percent: data.score_percent,
        results: data.results || [],
      }));
      window.location.href = "/review";
    } catch (e) {
      info.textContent = `상세 조회 실패: ${e.message}`;
    }
  }

  async function loadHistory() {
    const user = input.value.trim();
    if (!user) { info.textContent = "이름을 입력해 주세요."; list.innerHTML = ""; return; }
    info.textContent = "불러오는 중...";
    try {
      const res  = await fetch(`${API_BASE}/history/${encodeURIComponent(user)}?limit=30`);
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || `HTTP ${res.status}`);
      info.textContent = `${data.user_name} 님 이력 ${data.attempts.length}건`;
      renderRows(data.attempts);
    } catch (e) {
      info.textContent = `조회 실패: ${e.message}`;
      list.innerHTML = "";
    }
  }

  document.getElementById("loadHistoryBtn").addEventListener("click", loadHistory);
  if (input.value) loadHistory();
  </script>
</body>
</html>